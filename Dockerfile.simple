FROM node:25-alpine AS deps
WORKDIR /app
COPY package*.json ./
RUN npm ci --omit=dev

FROM node:25-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production

# Copy pre-built standalone output
COPY .next/standalone/.openclaw/workspace/projects/mission-control ./
COPY .next/static ./.next/static
COPY public ./public
# Override with full production dependencies (standalone trace misses some)
COPY --from=deps /app/node_modules ./node_modules

EXPOSE 3000
CMD ["node", "server.js"]
