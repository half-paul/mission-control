# Mission Control Environment Configuration

# ─── Deployment Mode ────────────────────────────────────────
# Single Container (default): Frontend + API in same container
# Multi-Container (optional): Frontend and API run separately

# ─── Base URL ───────────────────────────────────────────────
# Public base URL for the application
# Local:      http://localhost:4000
# Production: https://mission-control.uchitel.ca
BASE_URL=http://localhost:4000

# ─── Authentication ─────────────────────────────────────────
# NextAuth secret (must be at least 32 characters in production)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-in-production-min-32-chars

# NextAuth URL (where authentication callbacks return to)
# Defaults to BASE_URL if not set
NEXTAUTH_URL=${BASE_URL}

# ─── Database ───────────────────────────────────────────────
# PostgreSQL connection string
# Docker:     postgresql://mc:mc@postgres:5432/mission_control
# Local Dev:  postgresql://mc:mc@localhost:5432/mission_control
DATABASE_URL=postgresql://mc:mc@postgres:5432/mission_control

# ─── API Configuration (Client-Side) ────────────────────────
# NEXT_PUBLIC_* variables are exposed to the browser

# API Base URL (client-side)
# - Empty (default): Use relative URLs (same container deployment)
# - Set URL: Use absolute URLs (multi-container deployment)
# 
# Single Container:  NEXT_PUBLIC_API_URL=
# Multi-Container:   NEXT_PUBLIC_API_URL=https://api.mission-control.uchitel.ca
NEXT_PUBLIC_API_URL=

# ─── Projects Import Path ───────────────────────────────────
# Path to workspace projects for STATUS.md import
# Docker:    /data/projects
# Local Dev: /home/user/.openclaw/workspace/projects
PROJECTS_PATH=/data/projects

# ─── CORS Origins (Optional) ────────────────────────────────
# Additional allowed CORS origins (comma-separated)
# Example: https://admin.example.com,https://mobile.example.com
# CORS_ORIGINS=

# ─── Node Environment ───────────────────────────────────────
# development | production | test
NODE_ENV=production

# ─── Deployment Examples ────────────────────────────────────

# Example 1: Local Development
# BASE_URL=http://localhost:4000
# NEXTAUTH_SECRET=dev-secret-change-in-production
# NEXTAUTH_URL=http://localhost:4000
# DATABASE_URL=postgresql://mc:mc@localhost:5432/mission_control
# NEXT_PUBLIC_API_URL=
# NODE_ENV=development

# Example 2: Production - Single Container (Frontend + API)
# BASE_URL=https://mission-control.uchitel.ca
# NEXTAUTH_SECRET=<generate-with-openssl-rand-base64-32>
# NEXTAUTH_URL=https://mission-control.uchitel.ca
# DATABASE_URL=postgresql://mc_prod:secure_password@postgres:5432/mission_control
# NEXT_PUBLIC_API_URL=
# NODE_ENV=production

# Example 3: Production - Multi-Container (Separate API)
# BASE_URL=https://mission-control.uchitel.ca
# NEXTAUTH_SECRET=<generate-with-openssl-rand-base64-32>
# NEXTAUTH_URL=https://mission-control.uchitel.ca
# DATABASE_URL=postgresql://mc_prod:secure_password@db-server:5432/mission_control
# NEXT_PUBLIC_API_URL=https://api.mission-control.uchitel.ca
# NODE_ENV=production
